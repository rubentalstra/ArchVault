# =============================================================================
# ArchVault Production Environment Variables
# Copy this file to .env and fill in the required values.
# =============================================================================

# --- Required ---

# Secret key for Better Auth session signing.
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL where ArchVault is accessible (no trailing slash).
BETTER_AUTH_URL=https://archvault.example.com

# PostgreSQL credentials (used by both app and db services in compose.prod.yaml).
POSTGRES_USER=archvault
POSTGRES_PASSWORD=
POSTGRES_DB=archvault

# --- Optional: Reverse Proxy (Traefik profile) ---

# Domain for Traefik host rule (used by the built-in Traefik Compose profile).
DOMAIN=archvault.example.com

# Email for Let's Encrypt certificate notifications.
ACME_EMAIL=admin@example.com

# --- Optional: Auto-Migration ---

# Run database migrations automatically on container start (default: true).
AUTO_MIGRATE=true

# --- Optional: OAuth Providers ---

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Provider toggles (auto-enabled when both ID + secret are set).
# AUTH_SOCIAL_GITHUB_ENABLED=
# AUTH_SOCIAL_GOOGLE_ENABLED=
# AUTH_SOCIAL_MICROSOFT_ENABLED=

# --- Optional: Email (SMTP) ---

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@archvault.example.com

# --- Optional: Blocks Registry (Phase 5) ---

# GITHUB_PAT=
# REGISTRY_REPO=

# --- Optional: OpenTelemetry ---

# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=archvault
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
# OTEL_AUTH_TYPE=none
# OTEL_LOGS_ENABLED=false
